# Telegram bot settings
BOT_TOKEN=your_bot_token_here

# Optional settings for YouTube downloads
# Use either raw cookie content in YOUTUBE_COOKIES, or a local cookie file path in YOUTUBE_COOKIES_PATH.
YOUTUBE_COOKIES_PATH=/path/to/youtube_cookies.txt
#YOUTUBE_COOKIES="# Netscape HTTP Cookie File\n..."
# Alternatively, use base64 content for Railway/Secrets (single-line):
#YOUTUBE_COOKIES_B64=BASE64_OF_COOKIES_TXT
YOUTUBE_PO_TOKEN=your_po_token_here
YOUTUBE_VISITOR_DATA=your_visitor_data_here
YOUTUBE_API_KEY=your_google_api_key_here

# Web App URL (must be HTTPS)
WEB_APP_URL=https://your-app-domain.com/webapp

# Archive sync (optional)
# ADMIN_IDS=123456789
# SYNC_CHAT_ID=-1001234567890
# ARCHIVE_SYNC_MAX=2000
# ARCHIVE_SYNC_GAP=200
# ARCHIVE_SYNC_DELAY=0.25
# ARCHIVE_SYNC_ON_START=0
